# ============================================================
# CHAT HUB - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: NEVER commit .env to git - it contains secrets!
# ============================================================

# ============================================================
# Server Configuration
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# Database Configuration
# ============================================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# Get this from: MongoDB Atlas → Connect → Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority&appName=Cluster0

# ============================================================
# Authentication
# ============================================================
# JWT Secret - Use a strong random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string_in_production

# ============================================================
# CORS Configuration
# ============================================================
# Your frontend URL - required for CORS policy
# Development: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
# Multiple origins (optional): http://localhost:3000,https://example.com
CORS_ORIGIN=http://localhost:3000

# ============================================================
# Image Upload Service (Cloudinary)
# ============================================================
# Get these from: https://cloudinary.com/console/settings/api-keys
# CLOUDINARY_CLOUD_NAME: Your cloud name
# CLOUDINARY_API_KEY: Your API key (contains numbers/alphanumeric)
# CLOUDINARY_API_SECRET: Your API secret (long alphanumeric string)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key_numbers
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_long_string

# ============================================================
# Optional: Socket.io Configuration
# ============================================================
# Default: true (enables real-time messaging)
SOCKET_ENABLED=true

# ============================================================
# SECURITY REMINDERS
# ============================================================
# ⚠️  NEVER share or commit this file!
# ⚠️  NEVER use the same password as your database username!
# ⚠️  NEVER hardcode these values in your code!
# ⚠️  Use environment variables defined in your deployment platform!
# ⚠️  Rotate these credentials periodically!

