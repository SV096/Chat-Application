# Frontend Environment Variables
# Copy this file to .env.local and fill in your own values

# API Base URL
# Development: http://localhost:5000/api
# Production: https://your-render-backend.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# Socket.io Server URL
# Development: http://localhost:5000
# Production: https://your-render-backend.onrender.com
REACT_APP_SOCKET_URL=http://localhost:5000

# Cloudinary Configuration
REACT_APP_CLOUDINARY_NAME=your_cloudinary_name
REACT_APP_CLOUDINARY_PRESET=your_unsigned_preset

# Environment
REACT_APP_ENV=development
